# ═══════════════════════════════════════════════
#   MINEBEAN SNIPER SEPI — Environment
#   Strategy: Skip whale rounds, play only quiet
# ═══════════════════════════════════════════════

# ── Wallet ───────────────────────────────────
PRIVATE_KEY=0x...
AGENT_ADDRESS=0x...
ANTHROPIC_API_KEY=sk-ant-...

# ── Deploy Amount ────────────────────────────
# ETH per BLOCK (bukan per round)
# $30 budget rekomendasi: 0.001 ETH/block
ETH_PER_ROUND=0.001

# ── Round Filter (KUNCI STRATEGY) ───────────

# Skip jika total pool sudah > ini ETH
# Round tadi = 0.45 ETH → whale, harus skip
# Setting 0.05 = skip jika ada yang deploy > 0.05 ETH total
MAX_POOL_ETH=0.05

# Skip jika block target sudah > ini ETH
MAX_BLOCK_ETH=0.005

# Skip jika share kamu < ini persen di block target
MIN_SHARE_PCT=5

# Tunggu N detik dulu sebelum deploy
# Lihat siapa masuk, baru decide
WAIT_SECONDS=20

# Force play meski ramai jika beanpot >= ini BEAN
FORCE_PLAY_BEANPOT=200

# ── AI ───────────────────────────────────────
AI_MODEL=claude-opus-4-6
AI_CACHE_ROUNDS=10

# ── Claim ────────────────────────────────────
CLAIM_ETH_MIN=0.001
CLAIM_BEAN_MIN=1

# ── Auto Stake ───────────────────────────────
AUTO_STAKE=true
STAKE_MIN_BEAN=5

# ── Infra ────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
PORT=3001
